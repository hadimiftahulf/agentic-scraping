{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@db/*": ["packages/db/src"],
      "@utils/*": ["packages/utils/src"],
      "@config/*": ["packages/config/src"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next"
  ]
}
