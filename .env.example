# ===================================
# Database Configuration
# ===================================
DATABASE_URL="postgresql://botuser:botpassword@localhost:5432/botdb?schema=public"

# ===================================
# Redis Configuration
# ===================================
REDIS_URL="redis://localhost:6379"

# ===================================
# Facebook Session (CRITICAL - Keep Secret)
# ===================================
# Path to encrypted session file (auto-generated)
FB_SESSION_PATH="./session/fb_session.json"

# Encryption key for session file (generate with: openssl rand -base64 32)
SESSION_ENCRYPT_KEY="your-32-byte-encryption-key-here"

# ===================================
# Scraper Configuration
# ===================================
# Target URL to scrape
TARGET_URL="https://www.jakartanotebook.com/category/laptop"

# Scraping interval in minutes
SCRAPER_INTERVAL_MINUTES=20

# ===================================
# Product Processing Configuration
# ===================================
# Price markup percentage (e.g., 25 = 25% markup)
PRICE_MARKUP_PERCENT=25

# Price range filter (in Rupiah)
MIN_PRICE=0
MAX_PRICE=50000000

# Blacklist keywords (comma-separated)
BLACKLIST_KEYWORDS="bundle,rusak,damaged,second"

# ===================================
# Posting Configuration
# ===================================
# Maximum posts per day (to avoid ban)
MAX_POST_PER_DAY=8

# Delay between posts in seconds
POST_DELAY_SECONDS=300

# Watermark configuration
WATERMARK_TEXT="TokoGue.id"
WATERMARK_POSITION="bottom-right"
WATERMARK_OPACITY=0.7
WATERMARK_FONT_SIZE=40

# ===================================
# API Configuration
# ===================================
PORT=3001
NODE_ENV="development"

# CORS allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:3000"

# ===================================
# Next.js Frontend
# ===================================
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ===================================
# Optional: Telegram Notifications
# ===================================
# TELEGRAM_BOT_TOKEN="your-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"
